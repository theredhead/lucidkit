{
  "name": "@theredhead/ui-forms",
  "version": "0.0.1",
  "description": "Theredhead UI Forms - JSON-driven, signal-based form engine with dynamic field rendering",
  "private": false,
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@theredhead/foundation": "0.0.1",
    "@theredhead/ui-kit": "0.0.1"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json -w"
  },
  "ngPackage": {
    "$schema": "node_modules/ng-packagr/ng-package.schema.json",
    "dest": "../../dist/ui-forms",
    "lib": {
      "entryFile": "src/public-api.ts"
    }
  }
}
