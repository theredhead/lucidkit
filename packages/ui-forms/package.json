{
  "name": "@theredhead/lucid-forms",
  "version": "0.1.6",
  "description": "Schema-driven, signal-based Angular form engine with validation, conditional logic, and a visual form designer",
  "license": "MIT",
  "author": "theredhead",
  "keywords": [
    "angular",
    "ui",
    "forms",
    "lucidkit",
    "signals",
    "standalone",
    "schema-driven",
    "dynamic-forms",
    "form-validation",
    "form-builder",
    "form-designer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theredhead/lucidkit.git",
    "directory": "packages/ui-forms"
  },
  "homepage": "https://github.com/theredhead/lucidkit#readme",
  "bugs": {
    "url": "https://github.com/theredhead/lucidkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@theredhead/lucid-foundation": "^0.1.0",
    "@theredhead/lucid-kit": "^0.1.0"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "build:watch": "ng-packagr -p ng-package.json -c tsconfig.lib.json -w"
  },
  "ngPackage": {
    "$schema": "node_modules/ng-packagr/ng-package.schema.json",
    "dest": "../../dist/ui-forms",
    "lib": {
      "entryFile": "src/public-api.ts"
    }
  }
}
