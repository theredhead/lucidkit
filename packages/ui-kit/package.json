{
  "name": "@theredhead/lucid-kit",
  "version": "0.1.4",
  "description": "Standalone, signal-based Angular UI component library — buttons, inputs, tables, filters, autocomplete, dropdowns, and more",
  "license": "MIT",
  "author": "theredhead",
  "keywords": [
    "angular",
    "ui",
    "component-library",
    "lucidkit",
    "signals",
    "standalone",
    "onpush",
    "button",
    "input",
    "table",
    "filter",
    "autocomplete",
    "dropdown",
    "datepicker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theredhead/lucidkit.git",
    "directory": "packages/ui-kit"
  },
  "homepage": "https://github.com/theredhead/lucidkit#readme",
  "bugs": {
    "url": "https://github.com/theredhead/lucidkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "dependencies": {
    "@theredhead/lucid-theme": "^0.1.0"
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "build:watch": "ng-packagr -p ng-package.json -c tsconfig.lib.json -w",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "ngPackage": {
    "$schema": "node_modules/ng-packagr/ng-package.schema.json",
    "dest": "../../dist/ui-kit",
    "lib": {
      "entryFile": "src/public-api/index.ts"
    }
  }
}
