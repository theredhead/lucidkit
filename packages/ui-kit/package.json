{
  "name": "@sigmax/ui-kit",
  "version": "0.0.1",
  "description": "Sigmax UI Kit - Core Components Library",
  "private": false,
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/material": "^21.0.0"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json -w"
  },
  "ngPackage": {
    "$schema": "node_modules/ng-packagr/ng-package.schema.json",
    "dest": "../../dist/ui-kit",
    "lib": {
      "entryFile": "src/public-api/index.ts"
    }
  }
}
