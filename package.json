{
  "name": "theredhead-fe-workspace",
  "version": "0.0.0",
  "description": "theredhead Frontend Component Libraries Workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint --workspaces",
    "storybook": "ng run storybook-host:storybook",
    "build-storybook": "ng run storybook-host:build-storybook"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.2",
    "@analogjs/vitest-angular": "^2.2.2",
    "@angular-devkit/architect": "^0.2102.2",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-devkit/core": "^21.0.0",
    "@angular/animations": "^21.0.0",
    "@angular/build": "^21.1.0",
    "@angular/cdk": "^21.0.0",
    "@angular/cli": "^21.1.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@compodoc/compodoc": "^1.1.16",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/angular": "^10.1.11",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "jsdom": "^27.4.0",
    "ng-packagr": "^21.0.0",
    "storybook": "^10.1.11",
    "typescript": "^5.9.0",
    "vitest": "^4.0.17",
    "zone.js": "^0.16.0"
  }
}
