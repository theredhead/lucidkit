{
  "name": "sigmax-fe-workspace",
  "version": "0.0.0",
  "description": "Sigmax Frontend Component Libraries Workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
